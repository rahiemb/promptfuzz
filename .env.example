# PromptFuzz Environment Variables Example

# LiteLLM Target Configuration
# If your promptfuzz.yaml uses ${LITELLM_API_KEY} for custom routing
# LITELLM_API_KEY=your_litellm_api_key_here
# LITELLM_BASE_URL=https://api.your-custom-proxy.com/v1

# Standard Model Provider API Keys & Base URLs (Used natively by LiteLLM)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# COHERE_API_KEY=your_cohere_api_key_here
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Local Model Examples (e.g. Ollama, vLLM)
# OLLAMA_API_BASE=http://localhost:11434

# Detector Defaults
# EMBEDDING_MODEL=text-embedding-3-small
# LLM_JUDGE_MODEL=gpt-4o-mini

# Dashboard Settings
# HOST=127.0.0.1
# PORT=8000
